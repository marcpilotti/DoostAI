# ===================================
# DOOST AI — Environment Variables
# Copy to .env.local and fill in values
# ===================================

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# --- Clerk Auth ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/chat
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/chat

# --- Supabase / PostgreSQL ---
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT].supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- AI Models ---
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# --- Brand Extraction ---
FIRECRAWL_API_KEY=fc-...
ROARING_API_KEY=...
ROARING_API_URL=https://api.roaring.io

# --- Token Encryption (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))") ---
TOKEN_ENCRYPTION_KEY=...

# --- Ad Platforms — Meta ---
META_APP_ID=...
META_APP_SECRET=...
META_BUSINESS_MANAGER_ID=...
META_SYSTEM_USER_TOKEN=...

# --- Ad Platforms — Google ---
GOOGLE_ADS_DEVELOPER_TOKEN=...
GOOGLE_ADS_MCC_ID=...
GOOGLE_ADS_CLIENT_ID=...
GOOGLE_ADS_CLIENT_SECRET=...
GOOGLE_ADS_REFRESH_TOKEN=...

# --- Ad Platforms — LinkedIn ---
LINKEDIN_CLIENT_ID=...
LINKEDIN_CLIENT_SECRET=...

# --- Cloudflare R2 Storage ---
R2_ACCOUNT_ID=...
R2_ACCESS_KEY_ID=...
R2_SECRET_ACCESS_KEY=...
R2_BUCKET_NAME=doost-creatives
R2_PUBLIC_URL=https://creatives.doost.ai

# --- Upstash Redis ---
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# --- Inngest ---
INNGEST_EVENT_KEY=...
INNGEST_SIGNING_KEY=...

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# --- Email (Resend) ---
RESEND_API_KEY=re_...

# --- Observability ---
SENTRY_DSN=https://...@sentry.io/...
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com
